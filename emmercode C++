void console() {
  Serial.println(analogRead(A0));
  delay(3 * 1000);
}
// Describe this function...
// Describe this function...
void concept() {
  if (analogRead(A0) < 20) {
    fill_solid(ledstrip, NUM_LEDS, CRGB(0, 55, 255)); FastLED.show();
  } else {
    setupoled();
    display.clearDisplay();
    fill_solid(ledstrip, NUM_LEDS, CRGB(0, 0, 0)); FastLED.show();
  }
}

void setup() {
	Serial.begin(115200);
  FastLED.addLeds<WS2812, 10, GRB>(ledstrip, NUM_LEDS);

  Wire.begin();
  Wire.setWireTimeout();
  i2cSelectChannel(0xff);
  leaphyProgram();
}

